// Singpass clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace singpass {

    entity Identity {
        id: string @unique
        externalId: string
        jurisdiction: string
        verified: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Credential {
        id: string @unique
        identityId: string
        type: string
        issuer: string
        issuedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Consent {
        id: string @unique
        identityId: string
        purpose: string
        granted: boolean
        expiresAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Transaction {
        id: string @unique
        identityId: string
        type: string
        amount: float
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Document {
        id: string @unique
        identityId: string
        type: string
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity VerificationRequest {
        id: string @unique
        identityId: string
        verifier: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
